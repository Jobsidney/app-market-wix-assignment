###############################################################################
# Server environment template (used by Node/Express backend)
# Copy to: .env
###############################################################################

# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app_market
ENCRYPTION_KEY=replace-with-32-plus-char-secret-key
HUBSPOT_CLIENT_ID=replace-with-hubspot-client-id
HUBSPOT_CLIENT_SECRET=replace-with-hubspot-client-secret
HUBSPOT_REDIRECT_URI=http://localhost:8787/oauth/hubspot/callback
APP_INTERNAL_ID=wix-hubspot-integration

# Recommended for secure Wix dashboard auth mode
# Get from Wix Dev Center -> your app -> OAuth settings -> App secret
WIX_APP_SECRET=

# Optional legacy/demo auth mode (only if WIX_APP_SECRET is not set)
APP_MARKET_API_KEY=

# Optional webhook hardening
WEBHOOK_HMAC_SECRET=
WIX_AUTOMATION_WEBHOOK_KEY=

# Optional for HubSpot -> Wix direct contact writes
WIX_API_KEY=

# Optional for HubSpot webhook registration script
HUBSPOT_APP_ID=
HUBSPOT_DEVELOPER_API_KEY=

# Security mode
# standard = local dev friendly
# locked   = requires WEBHOOK_HMAC_SECRET and (WIX_APP_SECRET or APP_MARKET_API_KEY)
SYNC_SECURITY_MODE=standard

# Optional
PORT=8787
