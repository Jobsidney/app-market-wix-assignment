###############################################################################
# Frontend (Vite/Wix dashboard) environment template
# Copy to: .env.local
###############################################################################

# Optional local dev fallback only (used when WIX_APP_SECRET is not set on server)
PUBLIC_DEFAULT_WIX_SITE_ID=demo-site

# Optional only when APP_MARKET_API_KEY mode is used without WIX_APP_SECRET
PUBLIC_APP_MARKET_API_KEY=

# Optional API base override for local/frontend testing
# Default is http://localhost:8787 when running on localhost
PUBLIC_API_BASE_URL=http://localhost:8787
